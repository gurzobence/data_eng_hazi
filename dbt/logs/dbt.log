    from "warehouse"."main"."stg_bikeshare"
),
all_stations as (
    select * from start_stations
    union
    select * from end_stations
)

select
    station_id,
    max(station_name) as station_name,
    max(lat) as latitude,
    max(lng) as longitude
from all_stations
where station_id is not null
group by station_id
  );

